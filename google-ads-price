# Script: Alerta de Saldo Baixo — Google Ads Scripts
 
## 1. Objetivo
 
Monitorar automaticamente o saldo/orçamento de uma conta do Google Ads e enviar um
e-mail de alerta quando o saldo estimado atingir um limite mínimo definido pelo usuário.
Elimina a necessidade de entrar manualmente na conta para conferir se ela está prestes
a ficar sem saldo (o que pararia as campanhas ativas).
 
- **Nome do script:** Saldo baixo
- **Arquivo:** Code.gs
- **Plataforma:** Google Ads Scripts (Apps Script)
- **Execução recomendada:** agendada (1x por dia, via relógio de agendamento em *Scripts*)
---
 
## 2. Duas versões do script
 
Existem dois cenários possíveis, dependendo do tipo de faturamento da conta:
 
| Cenário | Método usado | Quando se aplica |
|---|---|---|
| **A — Conta com Ordem de Orçamento (Budget Order)** | `AdsApp.budgetOrders()` | Contas com faturamento consolidado/pós-pago, comum em agências e grandes anunciantes |
| **B — Conta pré-paga (cartão de crédito)** | `AdsApp.currentAccount().getStatsFor()` + valor de investimento controlado manualmente | Maioria das contas de clientes pequenos/PMEs |
 
> ⚠️ Importante: `AdsApp.budgetOrders()` **só retorna resultados em contas com ordem de
> orçamento cadastrada**. Se a conta for pré-paga comum, o script sempre cairá no bloco
> de "não encontrei orçamento ativo". Por isso, use a **Versão B** para a maioria dos casos.
 
---
 
## 3. Versão A — Com Budget Order
 
```javascript
var EMAIL = "seuemail@gmail.com";
var LIMITE_ALERTA = 2000;
var ENVIAR_ALERTA_TODO_DIA = false;
 
function main() {
  var account = AdsApp.currentAccount();
  var currency = account.getCurrencyCode();
 
  var orders = AdsApp.budgetOrders()
    .withCondition("Status = ACTIVE")
    .get();
 
  if (!orders.hasNext()) {
    MailApp.sendEmail(
      EMAIL,
      "[Google Ads] Nao encontrei orcamento ativo",
      "Conta: " + account.getName() + "\n" +
      "ID: " + account.getCustomerId() + "\n\n" +
      "Nao encontrei uma ordem de orcamento ativa nesta conta."
    );
    return;
  }
 
  var order = orders.next();
  var spendingLimit = order.getSpendingLimit();
 
  if (spendingLimit === null) {
    Logger.log("A ordem de orcamento ativa nao tem limite de gastos.");
    return;
  }
 
  var start = order.getStartDateTime();
  var startDate = toYyyyMmDd(start);
 
  var today = Utilities.formatDate(
    new Date(),
    account.getTimeZone(),
    "yyyyMMdd"
  );
 
  var cost = account.getStatsFor(startDate, today).getCost();
 
  var saldoCalculado = spendingLimit - cost;
  var saldoNaConta = Math.max(0, saldoCalculado);
  var excessoEstimado = Math.max(0, cost - spendingLimit);
 
  Logger.log("Conta: " + account.getName());
  Logger.log("Saldo estimado: " + formatMoney(saldoNaConta, currency));
  Logger.log("Gasto no periodo: " + formatMoney(cost, currency));
  Logger.log("Limite de orcamento: " + formatMoney(spendingLimit, currency));
 
  var precisaAlertar = saldoNaConta <= LIMITE_ALERTA;
 
  if (!precisaAlertar && !ENVIAR_ALERTA_TODO_DIA) {
    Logger.log("Saldo acima do limite de alerta. Nada a fazer.");
    return;
  }
 
  var props = PropertiesService.getScriptProperties();
  var chave = "ultimoAlerta_" + account.getCustomerId();
  var ultimoEnviado = props.getProperty(chave);
 
  if (!ENVIAR_ALERTA_TODO_DIA && ultimoEnviado === today) {
    Logger.log("Alerta ja enviado hoje. Ignorando.");
    return;
  }
 
  var assunto = precisaAlertar
    ? "[Google Ads] Saldo baixo - " + account.getName()
    : "[Google Ads] Status diario de saldo - " + account.getName();
 
  var corpo =
    "Conta: " + account.getName() + "\n" +
    "ID: " + account.getCustomerId() + "\n\n" +
    "Limite de orcamento: " + formatMoney(spendingLimit, currency) + "\n" +
    "Gasto no periodo: " + formatMoney(cost, currency) + "\n" +
    "Saldo estimado: " + formatMoney(saldoNaConta, currency) + "\n" +
    (excessoEstimado > 0
      ? "\nAtencao: o gasto ja ultrapassou o limite em " + formatMoney(excessoEstimado, currency) + "\n"
      : "\n") +
    (precisaAlertar
      ? "O saldo esta abaixo do limite de alerta configurado (" + formatMoney(LIMITE_ALERTA, currency) + ")."
      : "Alerta diario ativado - segue o status atual da conta.");
 
  MailApp.sendEmail(EMAIL, assunto, corpo);
  props.setProperty(chave, today);
 
  Logger.log("E-mail enviado para " + EMAIL);
}
 
// A API do Google Ads Scripts retorna a data de inicio da ordem
// como um objeto {year, month, day, ...}, nao um Date do JS
function toYyyyMmDd(dateTimeObj) {
  var mm = ("0" + dateTimeObj.month).slice(-2);
  var dd = ("0" + dateTimeObj.day).slice(-2);
  return "" + dateTimeObj.year + mm + dd;
}
 
function formatMoney(value, currency) {
  return currency + " " + value.toFixed(2).replace(".", ",");
}
```
 
